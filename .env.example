# ── Database ───────────────────────────────────────────────────────────────
POSTGRES_USER=finplatform
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=indian_financials
DATABASE_URL=postgresql+asyncpg://finplatform:change_me_strong_password@db:5432/indian_financials

# ── API Keys (optional but recommended) ───────────────────────────────────
# Financial Modeling Prep (FMP) - https://financialmodelingprep.com
FMP_API_KEY=your_fmp_api_key_here

# Alpha Vantage - https://www.alphavantage.co
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# NSE India (no key needed, but rate limit headers may require user-agent)
NSE_USER_AGENT="Mozilla/5.0 (compatible; IndianFinPlatform/1.0)"

# ── App Settings ───────────────────────────────────────────────────────────
BACKEND_URL=http://localhost:8000
SECRET_KEY=change_me_to_a_long_random_string
LOG_LEVEL=INFO
MAX_COMPANIES_PER_REQUEST=100
MAX_YEARS=10
ETL_CONCURRENCY=4

# ── Rate Limiting ──────────────────────────────────────────────────────────
SCREENER_RATE_LIMIT_RPS=2
NSE_RATE_LIMIT_RPS=3
BSE_RATE_LIMIT_RPS=3

# ── pgAdmin (dev only) ─────────────────────────────────────────────────────
PGADMIN_EMAIL=admin@finplatform.local
PGADMIN_PASSWORD=admin
